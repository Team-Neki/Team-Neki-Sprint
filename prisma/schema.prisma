// Prisma schema for Sprint — Jira + Wiki in one app
// datasource: PostgreSQL (existing DB via DATABASE_URL)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Auth.js (NextAuth) models ----------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(MEMBER)
  createdAt     DateTime  @default(now())
  // 프로필 연락처(B5, additive). 없을 수 있음.
  phone         String?

  // 팀 소속(단일). 한 사람 = 한 팀. 배정은 팀 관리 UI에서 수동으로.
  teamId String?
  team   Team?   @relation(fields: [teamId], references: [id], onDelete: SetNull)

  accounts Account[]
  sessions Session[]

  ownedProjects     Project[]      @relation("ProjectOwner")
  ownedEpics        Epic[]         @relation("EpicOwner")
  assignedTasks     Task[]         @relation("TaskAssignee")
  createdTasks      Task[]         @relation("TaskReporter")
  // 참조(c.c.)로 걸린 태스크들(다대다).
  ccTasks           Task[]         @relation("TaskCc")
  comments          Comment[]
  wikiComments      WikiComment[]
  authoredPages     WikiPage[]     @relation("PageAuthor")
  editedPages       WikiPage[]     @relation("PageEditor")
  editedRevisions   WikiRevision[] @relation("RevisionEditor")
  wikiFavorites     WikiFavorite[]
  wikiDrafts        WikiDraft[]
  activities        Activity[]
  // 알림(B5). 수신자/행위자 양방향.
  notifications     Notification[] @relation("NotifRecipient")
  sentNotifications Notification[] @relation("NotifActor")
  // MCP 연동용 개인 API 토큰.
  apiTokens         ApiToken[]
  announcements     Announcement[] @relation("AnnouncementAuthor")
}

/**
 * 대시보드 공지. 모든 멤버가 작성/수정할 수 있고, **삭제는 작성자만** 가능
 * (작성자가 사라진 공지는 ADMIN 이 정리). 본문은 위키와 동일한 Tiptap doc JSON.
 */
model Announcement {
  id        String   @id @default(cuid())
  title     String
  content   Json     @default("{}")
  authorId  String?
  author    User?    @relation("AnnouncementAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
}

/**
 * 앱 내부 알림(B5). 현재는 위키 본문 '@' 멘션 시 수신자별로 1건 생성.
 * entityType/entityId 로 대상(wiki/task/…)을 가리키고, 읽음 여부를 추적한다.
 */
model Notification {
  id         String   @id @default(cuid())
  userId     String // 수신자
  user       User     @relation("NotifRecipient", fields: [userId], references: [id], onDelete: Cascade)
  actorId    String? // 행위자(멘션한 사람)
  actor      User?    @relation("NotifActor", fields: [actorId], references: [id], onDelete: SetNull)
  type       String // "mention" | ...
  entityType String // "wiki" | "task" | ...
  entityId   String
  context    String? // 미리보기 텍스트(예: 페이지 제목)
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([userId, read, createdAt])
}

enum Role {
  ADMIN
  MEMBER
}

/**
 * MCP 연동용 개인 API 토큰(B: 셀프서비스 발급). 원문은 저장하지 않고 sha-256 해시만
 * 보관하며, 생성 시 1회만 노출한다. revokedAt 로 소프트 폐기.
 */
model ApiToken {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  tokenHash  String    @unique
  prefix     String
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  revokedAt  DateTime?

  @@index([userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------- Project / Jira side ----------

enum Status {
  BACKLOG
  TODO
  IN_PROGRESS
  DONE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum SprintStatus {
  PLANNED
  ACTIVE
  DONE
}

// 기간 단위. 하위에 팀 횡단 작업(Project)을 담는다.
model Sprint {
  id        String       @id @default(cuid())
  name      String
  startDate DateTime?
  endDate   DateTime?
  status    SprintStatus @default(PLANNED)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  projects Project[]
}

// 팀 횡단 작업(구 Initiative를 전환). key 없음 — 제목만.
model Project {
  id          String    @id @default(cuid())
  title       String
  description String?   @db.Text
  status      Status    @default(BACKLOG)
  priority    Priority  @default(MEDIUM)
  startDate   DateTime?
  dueDate     DateTime?
  ownerId     String?
  owner       User?     @relation("ProjectOwner", fields: [ownerId], references: [id])
  sprintId    String?
  sprint      Sprint?   @relation(fields: [sprintId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  epics  Epic[]
  labels LabelsOnProjects[]
}

// 팀 = 이슈 key 접두어 = 유저 그룹. 한 사람 = 한 팀.
model Team {
  id    String  @id @default(cuid())
  key   String  @unique // "DESIGN" — 이슈 key 접두어
  name  String
  color String?
  seq   Int     @default(0) // 팀 단위 이슈 번호 카운터(epic+task 공유)

  members User[]
  epics   Epic[]
  tasks   Task[]
}

model Epic {
  id          String    @id @default(cuid())
  number      Int // 팀 시퀀스. 표시 key = team.key-number
  title       String
  description String?   @db.Text
  status      Status    @default(BACKLOG)
  priority    Priority  @default(MEDIUM)
  startDate   DateTime?
  dueDate     DateTime?
  ownerId     String?
  owner       User?     @relation("EpicOwner", fields: [ownerId], references: [id])
  teamId      String
  team        Team      @relation(fields: [teamId], references: [id])
  projectId   String?
  project     Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tasks  Task[]
  labels LabelsOnEpics[]

  @@unique([teamId, number])
}

model Task {
  id          String    @id @default(cuid())
  number      Int // 팀 시퀀스. 표시 key = team.key-number
  title       String
  description String?   @db.Text
  status      Status    @default(TODO)
  priority    Priority  @default(MEDIUM)
  startDate   DateTime?
  dueDate     DateTime?
  // 맨데이(MD) 트래킹(B7). 태스크에만 저장하고, Epic/Project는 하위 합으로 계산(읽기전용).
  estimatedMd Float?
  actualMd    Float?
  // 칸반 컬럼 내 순서(B7-board). null=미정렬 → 컬럼 하단(nulls last). 재정렬 시 컬럼 재번호.
  boardOrder  Float?
  assigneeId  String?
  assignee    User?     @relation("TaskAssignee", fields: [assigneeId], references: [id])
  reporterId  String?
  reporter    User?     @relation("TaskReporter", fields: [reporterId], references: [id])
  teamId      String
  team        Team      @relation(fields: [teamId], references: [id])
  epicId      String?
  epic        Epic?     @relation(fields: [epicId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // 참조(c.c.) 수신자(다대다, implicit m2m). 담당자/보고자와 별개로, 티켓을 함께
  // 참조하도록 선택된 사용자들. 순서/역할 없이 집합만 관리한다.
  ccUsers User[] @relation("TaskCc")

  comments  Comment[]
  labels    LabelsOnTasks[]
  wikiLinks WikiPageTaskLink[]
  // 의존성(blocks/blockedBy). blocking=내가 blocker 인 엣지(내가 막는 태스크들),
  // blockedBy=내가 blocked 인 엣지(나를 막는 태스크들). 관계 해석은 TaskDependency 참조.
  blocking  TaskDependency[]   @relation("BlockerTask")
  blockedBy TaskDependency[]   @relation("BlockedTask")

  githubLinks GithubBranchLink[]

  @@unique([teamId, number])
}

/**
 * 태스크 의존성 엣지. blocker 가 완료돼야 blocked 를 진행할 수 있다
 * (blocked 는 blocker 에 의존/차단됨). 방향 있는 그래프이며, 추가 시 순환을 막는다
 * (server/actions/tasks.ts + lib/task-deps.ts wouldCreateCycle). 태스크 삭제 시 cascade.
 */
model TaskDependency {
  blockerId String
  blocker   Task     @relation("BlockerTask", fields: [blockerId], references: [id], onDelete: Cascade)
  blockedId String
  blocked   Task     @relation("BlockedTask", fields: [blockedId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([blockerId, blockedId])
  @@index([blockedId])
}

model Comment {
  id        String   @id @default(cuid())
  body      String   @db.Text
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 태스크 상세의 댓글 조회 + 태스크 삭제 cascade 스캔용(계속 자라는 테이블).
  @@index([taskId, createdAt])
}

model Label {
  id    String @id @default(cuid())
  name  String @unique
  color String @default("#94a3b8")

  projects LabelsOnProjects[]
  epics    LabelsOnEpics[]
  tasks    LabelsOnTasks[]
}

model LabelsOnProjects {
  projectId String
  labelId   String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  label     Label   @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([projectId, labelId])
}

model LabelsOnEpics {
  epicId  String
  labelId String
  epic    Epic   @relation(fields: [epicId], references: [id], onDelete: Cascade)
  label   Label  @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([epicId, labelId])
}

model LabelsOnTasks {
  taskId  String
  labelId String
  task    Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  label   Label  @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([taskId, labelId])
}

// ---------- Wiki side ----------

// 문서 그룹핑용 폴더. 페이지 중첩(WikiPage.parentId)과는 별개 타입이다.
// 폴더는 스스로 중첩되며(parentId), 페이지는 folderId로 최상위(부모 없는) 위치가 결정된다.
model WikiFolder {
  id        String       @id @default(cuid())
  name      String
  parentId  String? // 폴더 중첩 허용
  parent    WikiFolder?  @relation("FolderTree", fields: [parentId], references: [id], onDelete: Cascade)
  children  WikiFolder[] @relation("FolderTree")
  position  Int          @default(0)
  pages     WikiPage[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

/**
 * 위키 본문에 첨부한 이미지. 바이너리를 DB 에 저장(파일시스템 가정 없이 포터블)하고
 * GET /api/wiki/image/[id] 로 서빙한다. content-addressed(cuid) 라 캐시 immutable.
 * uploaderId 는 감사용 스칼라(FK 관계 없음 — 유저 삭제와 무관하게 이미지 보존).
 */
model WikiImage {
  id         String   @id @default(cuid())
  data       Bytes
  mimeType   String
  name       String?
  size       Int
  uploaderId String?
  createdAt  DateTime @default(now())
}

model WikiPage {
  id         String      @id @default(cuid())
  title      String
  content    Json        @default("{}") // Tiptap JSON document
  // 본문(content)의 순수 텍스트 사본. 전역 검색(globalSearch)의 본문 매칭용.
  // 저장 시 docToPlainText(content) 로 채운다(제목은 별도 검색). null=미백필.
  searchText String?
  parentId   String?
  parent     WikiPage?   @relation("PageTree", fields: [parentId], references: [id], onDelete: Cascade)
  children   WikiPage[]  @relation("PageTree")
  // 폴더는 페이지 삭제와 무관하므로 폴더 삭제 시 페이지는 보존(SetNull)한다.
  folderId   String?
  folder     WikiFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  position   Int         @default(0)
  authorId   String?
  author     User?       @relation("PageAuthor", fields: [authorId], references: [id])
  editorId   String?
  editor     User?       @relation("PageEditor", fields: [editorId], references: [id])
  // soft-delete(휴지통). null=활성, 값=휴지통에 있는 시각. 목록/트리는 null 만 노출.
  deletedAt  DateTime?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  revisions      WikiRevision[]
  taskLinks      WikiPageTaskLink[]
  favorites      WikiFavorite[]
  commentThreads WikiCommentThread[]
  drafts         WikiDraft[]

  @@index([deletedAt])
}

/**
 * 편집 중 임시 저장본(B-editor). 유저×페이지당 1건(@@id). 에디터가 디바운스로
 * 여기에 자동저장하고, 명시적 '저장' 시 WikiPage 로 커밋 후 삭제한다. '취소' 시도 삭제.
 * 보관 2주 — updatedAt 이 14일 지난 draft 는 만료로 간주(로드 시 무시·정리).
 */
model WikiDraft {
  pageId    String
  page      WikiPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  content   Json
  updatedAt DateTime @updatedAt

  @@id([pageId, userId])
  @@index([updatedAt])
}

// ---------- 위키 인라인 댓글(B10, 구글독스식) ----------

/**
 * 본문 텍스트 범위에 앵커된 댓글 스레드. 앵커 자체는 Tiptap 문서 content 의
 * commentMark(data-comment-thread=<id>)로 저장되고, 여기엔 스레드 메타(선택
 * 텍스트 스냅샷 quote · 해결 여부)와 댓글들을 담는다. 페이지 삭제 시 함께 삭제.
 */
model WikiCommentThread {
  id        String        @id @default(cuid())
  pageId    String
  page      WikiPage      @relation(fields: [pageId], references: [id], onDelete: Cascade)
  quote     String        @db.Text // 앵커된 텍스트 스냅샷(사이드바 표시용, 본문 변경돼도 맥락 유지)
  resolved  Boolean       @default(false)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  comments  WikiComment[]

  @@index([pageId, resolved])
}

model WikiComment {
  id        String            @id @default(cuid())
  threadId  String
  thread    WikiCommentThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  authorId  String
  author    User              @relation(fields: [authorId], references: [id])
  body      String            @db.Text
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([threadId, createdAt])
}

model WikiRevision {
  id        String   @id @default(cuid())
  pageId    String
  page      WikiPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  title     String
  content   Json
  editorId  String?
  editor    User?    @relation("RevisionEditor", fields: [editorId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())

  // 버전 히스토리 조회 + 페이지 영구삭제 cascade 스캔용. 저장마다 1건씩 쌓이는
  // 가장 빨리 자라는 테이블이라 pageId 인덱스가 필수.
  @@index([pageId, createdAt])
}

// 유저별 위키 페이지 즐겨찾기(별표). @@id 로 (userId,pageId) 유일. 순수 조인 테이블.
model WikiFavorite {
  userId    String
  pageId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  page      WikiPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([userId, pageId])
}

model WikiPageTaskLink {
  pageId String
  taskId String
  page   WikiPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  task   Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@id([pageId, taskId])
  // PK 는 pageId 선두라 태스크 상세의 "연결된 위키"(taskId 역방향) 조회를 못 탄다.
  @@index([taskId])
}

// ---------- Activity log ----------

model Activity {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  entityType String // "sprint" | "project" | "team" | "epic" | "task" | "wiki"
  entityId   String
  action     String // "created" | "updated" | "status_changed" | ...
  meta       Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
}

model GithubInstallation {
  id             String   @id @default(cuid())
  installationId Int      @unique // GitHub 설치 ID
  accountLogin   String // org/user 로그인명(빈 값 허용, webhook 로 보강)
  createdAt      DateTime @default(now())
}

model GithubBranchLink {
  id           String   @id @default(cuid())
  taskId       String
  task         Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  repoFullName String // "owner/repo"
  branchName   String
  branchUrl    String
  prNumber     Int?
  prState      String? // OPEN | CLOSED | MERGED
  prUrl        String?
  prTitle      String?
  createdById  String? // 앱으로 만든 사람(자동연결은 null)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([repoFullName, branchName]) // webhook 재전송 멱등 upsert 키
  @@index([taskId])
}
