# ---- Database (existing PostgreSQL) ----
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/sprint?schema=public"

# ---- Auth.js (NextAuth v5) ----
# Generate with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET="change-me"
# Behind an ingress/proxy this must be true so callback URLs resolve.
AUTH_TRUST_HOST="true"

# ---- Google Workspace SSO ----
# Create OAuth 2.0 credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: https://YOUR_DOMAIN/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Restrict login to this Google Workspace domain (e.g. musinsa.com). Leave empty to allow any Google account.
ALLOWED_EMAIL_DOMAIN=""

# ---- S3 (위키 본문 이미지 저장) ----
# 자격증명은 여기 두지 않는다. AWS SDK 기본 credential provider chain 사용
# (k8s: IRSA/IAM Role, 로컬: ~/.aws 프로필 또는 AWS_ACCESS_KEY_ID/SECRET env).
S3_BUCKET=""
S3_REGION="ap-northeast-2"
# S3 호환 스토리지(MinIO 등)로 붙일 때만. 실제 AWS S3 면 비워둔다.
S3_ENDPOINT=""
# MinIO 등 경로형 접근이 필요하면 true. AWS S3 는 비워둔다(가상 호스팅).
S3_FORCE_PATH_STYLE=""

# ---- GitHub App 연동 ----
# github.com/settings/apps 에서 App 생성 후 값 입력.
# 권한: Contents Read/Write, Pull requests Read, Metadata Read.
# 구독 이벤트: create, pull_request, installation.
# webhook URL: https://sprint.suitestudy.com:4641/api/github/webhook
# setup URL:   https://sprint.suitestudy.com:4641/api/github/setup
GITHUB_APP_ID=""
# PEM 개인키. 개행은 \n 로 이스케이프해 한 줄로 넣는다.
GITHUB_APP_PRIVATE_KEY=""
GITHUB_WEBHOOK_SECRET=""
