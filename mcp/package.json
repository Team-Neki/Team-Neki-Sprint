{
  "name": "@neki-team/sprint-mcp",
  "version": "0.1.0",
  "description": "MCP server for the Team Neki Sprint tracker (tickets + wiki)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Team-Neki/Team-Neki-Sprint.git",
    "directory": "mcp"
  },
  "keywords": ["mcp", "modelcontextprotocol", "sprint", "tickets", "wiki"],
  "type": "module",
  "bin": { "sprint-mcp": "dist/index.js" },
  "files": ["dist"],
  "engines": { "node": ">=18" },
  "publishConfig": { "access": "public" },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest run",
    "prepublishOnly": "npm run test && npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1",
    "zod": "^3"
  },
  "devDependencies": {
    "@types/node": "^20",
    "typescript": "^5",
    "vitest": "^4"
  }
}
